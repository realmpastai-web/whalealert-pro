# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Blockchain API Keys (get free keys from these services)
ETHERSCAN_API_KEY=your_etherscan_key_here
BSCSCAN_API_KEY=your_bscscan_key_here
SOLSCAN_API_KEY=your_solscan_key_here

# Bot Settings
DEFAULT_ALERT_THRESHOLD=100000
CHECK_INTERVAL_SECONDS=60
MAX_FREE_WATCHES=3
PREMIUM_ALERT_DELAY_SECONDS=30
FREE_ALERT_DELAY_SECONDS=120

# Database
DATABASE_PATH=./data/whalealert.db

# Logging
LOG_LEVEL=info
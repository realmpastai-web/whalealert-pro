{
  "name": "whalealert-pro",
  "version": "1.0.0",
  "description": "Discord bot for crypto whale alerts and blockchain monitoring",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker build -t whalealert-pro .",
    "docker:run": "docker-compose up -d"
  },
  "keywords": ["discord", "bot", "crypto", "whale", "alerts", "blockchain"],
  "author": "QuantBitRealm",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}